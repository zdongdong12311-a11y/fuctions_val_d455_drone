<launch>
  <include file="$(find ego_planner)/launch/advanced_param.xml">
    <arg name="map_size_x_" value="20.0"/>
    <arg name="map_size_y_" value="20.0"/>
    <arg name="map_size_z_" value="3.0"/>
    
    <!-- 替换为 VINS 定位的话题 -->
    <arg name="odometry_topic" value="/vins_estimator/odometry"/>
    <arg name="camera_pose_topic" value="/mavros/vision_pose/pose"/>
    
    <!-- 替换为实机 D455 对齐后的深度图话题 -->
    <arg name="depth_topic" value="/camera/aligned_depth_to_color/image_raw"/>
    <arg name="cloud_topic" value="/pcl_render_node/cloud"/>
    
    <!-- ⚠️注意：实机 D455 的真实内参 (需用 rostopic echo /camera/depth/camera_info 查看并修改这里) -->
    <arg name="cx" value="320.5"/>
    <arg name="cy" value="240.5"/>
    <arg name="fx" value="384.5"/>
    <arg name="fy" value="384.5"/>
    
    <!-- 实机动力学约束：放慢速度，安全第一 -->
    <arg name="max_vel" value="0.8"/>
    <arg name="max_acc" value="1.0"/>
    <arg name="planning_horizon" value="5.0"/>
    
    <!-- 占位符航点 -->
    <arg name="point_num" value="1"/>
    <arg name="point0_x" value="0.0"/> <arg name="point0_y" value="0.0"/> <arg name="point0_z" value="1.2"/>
    <arg name="point1_x" value="0.0"/> <arg name="point1_y" value="0.0"/> <arg name="point1_z" value="1.2"/>
    <arg name="point2_x" value="0.0"/> <arg name="point2_y" value="0.0"/> <arg name="point2_z" value="1.2"/>
    <arg name="point3_x" value="0.0"/> <arg name="point3_y" value="0.0"/> <arg name="point3_z" value="1.2"/>
    <arg name="point4_x" value="0.0"/> <arg name="point4_y" value="0.0"/> <arg name="point4_z" value="1.2"/>
    
    <arg name="flight_type" value="1"/> <!-- 接受 RViz 点击 -->
  </include>

  <!-- 轨迹翻译官 -->
  <node pkg="ego_planner" name="traj_server" type="traj_server" output="screen">
    <remap from="/position_cmd" to="/position_cmd"/>
    <remap from="/odom_world" to="/vins_estimator/odometry"/>
    <param name="traj_server/time_forward" value="1.0" type="double"/>
  </node>

  <!-- 鼠标/巡航翻译官 -->
  <node pkg="waypoint_generator" name="waypoint_generator" type="waypoint_generator">
      <remap from="~odom" to="/vins_estimator/odometry"/>
      <remap from="~goal" to="/move_base_simple/goal"/>
      <param name="waypoint_type" value="manual-lonely-waypoint"/>
  </node>
</launch>