<launch>
  <!-- 1. 静态 TF 桥梁：连接 vins_body 和相机 -->
  <!-- 注意：如果你之前改了代码叫 vins_body，这里就要用 vins_body -->
  <node pkg="tf" type="static_transform_publisher" name="vins_to_camera_tf" args="0.1 0 0 0 0 0 body camera_link 100" />

  <group ns="rtabmap">
    <!-- 2. RTAB-Map 主节点 -->
    <node name="rtabmap" pkg="rtabmap_slam" type="rtabmap" output="screen" args="">
      
      <!-- 3. 数据库文件路径 (请确保文件就在这个位置) -->
      <param name="database_path" type="string" value="/home/orangepi/rtabmap.db"/>

      <!-- 4. 关键：关闭增量内存（进入定位模式） -->
      <param name="Mem/IncrementalMemory" type="string" value="false"/>
      
      <!-- 5. 允许回环检测修正全局位姿 -->
      <param name="RGBD/OptimizeFromGraphEnd" type="string" value="false"/>

      <!-- 6. 坐标系与话题映射 -->
      <param name="frame_id" type="string" value="body"/>
      <param name="odom_frame_id" type="string" value="world"/>

      <remap from="rgb/image" to="/camera/color/image_raw"/>
      <remap from="depth/image" to="/camera/aligned_depth_to_color/image_raw"/>
      <remap from="rgb/camera_info" to="/camera/color/camera_info"/>
      <remap from="odom" to="/vins_estimator/odometry"/>

      <!-- 7. 优化参数 -->
      <param name="Kp/MaxFeatures" type="string" value="500"/>
      <param name="Rtabmap/DetectionRate" type="string" value="1"/>
      <param name="wait_for_transform_duration" type="double" value="0.5"/>
    </node>
  </group>
</launch>